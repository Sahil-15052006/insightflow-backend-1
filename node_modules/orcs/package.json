{
  "version": "0.0.1-preview.2",
  "name": "orcs",
  "bin": {
    "orcs": "./bin/cli.js"
  },
  "keywords": ["devtools", "process manager", "process orchestrator"],
  "dependencies": {
    "blessed": "^0.1.81",
    "commander": "^6.1.0",
    "react": "^16.13.1",
    "react-blessed": "^0.6.2",
    "yaml": "^1.10.0"
  },
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",    
    "clean": "npm-run-all clean:*",
    "clean:logs": "rimraf *.logs",
    "clean:runtime": "rimraf ./dist/runtime.js",    
    "clean:modules": "rimraf ./node_modules",
    "publish": "npm-run-all build"
  },
  "devDependencies": {
    "@rollup/plugin-json": "^4.1.0",
    "@rollup/plugin-typescript": "^6.0.0",
    "@types/blessed": "^0.1.17",
    "@types/node": "^14.11.1",
    "@types/react": "^16.9.49",
    "@types/react-blessed": "^0.3.2",
    "@types/yaml": "^1.9.7",
    "npm-run-all": "^4.1.5",
    "rimraf": "^3.0.2",
    "rollup": "^2.27.1",
    "tslib": "^2.0.1",
    "typescript": "^4.0.2"
  },
  "author": "Andrey Antipov",
  "license": "MIT"
}
