{
    "compilerOptions": 
    {
        "target": "es6",
        "moduleResolution": "node",
        "jsx": "react",
        "experimentalDecorators": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "noImplicitAny": true,
        "sourceMap": true,
        "baseUrl": "./src",
        "paths": {
            "Components":   ["./components/index.ts"],
            "Containers":   ["./containers/index.ts"]
        },
        "typeRoots": ["./node_modules/@types"]
    },
}